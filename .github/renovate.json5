{
  $schema: 'https://docs.renovatebot.com/renovate-schema.json',
  extends: [
    'config:best-practices'
  ],
  labels: [
    'dependencies',
    'automated-pr',
  ],
  dependencyDashboard: true,
  timezone: 'Europe/Copenhagen',
  schedule: [
    'after 12am and before 7am every weekday',
    'on sunday',
  ],
  automergeSchedule: [
    'after 12pm and before 4pm every weekday',
  ],
  vulnerabilityAlerts: {
    addLabels: [
      'vulnerability',
    ],
    additionalBranchPrefix: '',
  },
  major: {
    automerge: false,
  },
  minor: {
    automerge: false,
  },
  patch: {
    automerge: true,
  },
  rebaseWhen: 'auto',
  packageRules: [
    {
      "extends": [
        "helpers:pinGitHubActionDigests"
      ],
      "extractVersion": "^(?<version>v?\\d+\\.\\d+\\.\\d+)$",
      "versioning": "regex:^v?(?<major>\\d+)(\\.(?<minor>\\d+)\\.(?<patch>\\d+))?$",
      "recreateWhen": "always",
    }
  ],
  customManagers: [
    {
      customType: 'regex',
      managerFilePatterns: [
        '/^build_files/.*\\.sh$/',
      ],
      matchStrings: [
        '(?<depName>[^\\s"\']+)="?(?<currentValue>.[^"\'\\s]*)"?\\s+# renovate:\\s*datasource=(?<datasource>[^\\s]+)\\s+depName=(?<packageName>[^\\s]+)',
      ],
      datasourceTemplate: '{{{datasource}}}',
      packageNameTemplate: '{{{packageName}}}',
      versioningTemplate: 'semver',
    },
  ],
}
